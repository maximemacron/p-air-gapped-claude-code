# =============================================================================
# air-gapped-claude-code — Self-contained vLLM + Qwen inference image
#
# Built ONCE on a connected machine. Contains everything needed to run
# offline: vLLM, CUDA runtime, and model weights.
#
# Base: vllm/vllm-openai:v0.19.0 — official image with the exact CUDA/torch
# combination vLLM was compiled against. Avoids manual CUDA version matching.
#
# Only host requirement on the air-gapped machine:
#   - NVIDIA driver >= 525
#   - nvidia-container-toolkit
#
# Model: Qwen/Qwen2.5-7B-Instruct (BF16, runtime FP8 quantization)
#   - Download: ~14 GB BF16; vLLM quantizes to FP8 at load → ~7.5 GB in VRAM
#   - GPU: RTX 5000 Ada Generation (16 GB VRAM)
#   - KV cache: FP8, ~5.5 GB available at 0.90 utilization → ~65K token ceiling
#   - Max context: 65536 tokens — covers large file reads and long sessions
#   - Smaller than 14B but context window matters more than model size for a
#     coding assistant that holds entire codebases in context
#
# Layer order is intentional — model download is placed before any layer
# likely to change so it is not re-fetched on every rebuild:
#
#   1. Base image      (vLLM + CUDA + torch — never changes for a given tag)
#   2. Model download  (~8 GB — must not be invalidated by config changes)
#   3. Runtime config  (USER, HEALTHCHECK, CMD — free to change)
# =============================================================================
FROM vllm/vllm-openai:v0.19.0

# ── Non-root service account ──────────────────────────────────────────────────
RUN groupadd -r vllm 2>/dev/null || true \
    && useradd -r -g vllm -m -d /home/vllm vllm 2>/dev/null || true

# ── Download model weights (baked into image — no volume mount at runtime) ────
# HF_TOKEN is required to download the model (accept terms on huggingface.co
# first). The secret is mounted only during this RUN step and is never written
# to any image layer.
# Pass it with:  docker build --secret id=HF_TOKEN,env=HF_TOKEN ...
#
# --mount=type=cache persists the HuggingFace blob cache on the build machine.
# snapshot_download checks the cache before fetching each file, so rebuilds
# caused by layer invalidation do not re-fetch weights already present locally.
RUN --mount=type=secret,id=HF_TOKEN \
    --mount=type=cache,target=/root/.cache/huggingface \
    mkdir -p /models \
    && python3 -c "\
import os; \
from huggingface_hub import snapshot_download; \
secret = '/run/secrets/HF_TOKEN'; \
token = open(secret).read().strip() if os.path.exists(secret) else None; \
snapshot_download( \
    repo_id='Qwen/Qwen2.5-7B-Instruct', \
    local_dir='/models/qwen2.5-7b-fp8', \
    ignore_patterns=['*.gguf', 'original/*'], \
    token=token, \
)" \
    && chown -R vllm:vllm /models

USER vllm

ENV VLLM_V1=0
ENV VLLM_ALLOW_LONG_MAX_MODEL_LEN=1

# ── Healthcheck ───────────────────────────────────────────────────────────────
HEALTHCHECK --interval=30s --timeout=10s --start-period=120s --retries=3 \
  CMD curl -sf http://localhost:8000/health || exit 1

# ── Inference server ──────────────────────────────────────────────────────────
ENTRYPOINT ["vllm", "serve"]
CMD [ \
  "/models/qwen2.5-7b-fp8", \
  "--served-model-name",      "claude-3-5-sonnet-20241022", \
  "--quantization",           "fp8", \
  "--gpu-memory-utilization", "0.90", \
  "--max-model-len",          "65536", \
  "--kv-cache-dtype",         "fp8", \
  "--trust-remote-code", \
  "--enforce-eager", \
  "--max-num-seqs",           "4", \
  "--port",                   "8000", \
  "--host",                   "0.0.0.0", \
  "--enable-auto-tool-choice", \
  "--tool-call-parser",       "hermes" \
]
